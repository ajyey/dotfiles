// Zellij Configuration
// using the Rose Pine Moon theme to match WezTerm

theme "rose-pine-moon"

// Optional: you can customize UI and default layouts here
default_layout "default"
copy_on_select true

themes {
    rose-pine-moon {
        bg "#c4a7e7"
        fg "#e0def4"
        red "#eb6f92"
        green "#3e8fb0"
        blue "#9ccfd8"
        yellow "#f6c177"
        magenta "#c4a7e7"
        orange "#c4a7e7" // Overridden to match WezTerm's purple selection highlight
        cyan "#ea9a97"
        black "#393552"
        white "#e0def4"
    }
}

// ====================================================================
// Keybindings
// ====================================================================
// We use the "Option" (Alt) key for all Zellij interactions to completely
// separate Zellij navigation from WezTerm's native "CMD" navigation!
keybinds {
    shared_except "locked" {
        // Tab Management
        bind "Alt t" { NewTab; }
        bind "Alt [" { GoToPreviousTab; }
        bind "Alt ]" { GoToNextTab; }
        bind "Alt 1" { GoToTab 1; }
        bind "Alt 2" { GoToTab 2; }
        bind "Alt 3" { GoToTab 3; }
        bind "Alt 4" { GoToTab 4; }
        bind "Alt 5" { GoToTab 5; }
        bind "Alt 6" { GoToTab 6; }
        bind "Alt 7" { GoToTab 7; }
        bind "Alt 8" { GoToTab 8; }
        bind "Alt 9" { GoToTab 9; }

        // Pane Management
        bind "Alt d" { NewPane "Right"; }
        bind "Alt D" { NewPane "Down"; } // Shift+Option+D
        bind "Alt w" { CloseFocus; }
        bind "Alt f" { ToggleFloatingPanes; }

        // Pane Navigation
        bind "Alt Left" { MoveFocusOrTab "Left"; }
        bind "Alt Right" { MoveFocusOrTab "Right"; }
        bind "Alt Up" { MoveFocus "Up"; }
        bind "Alt Down" { MoveFocus "Down"; }
        
        // Vim-style Pane Navigation
        bind "Alt h" { MoveFocusOrTab "Left"; }
        bind "Alt l" { MoveFocusOrTab "Right"; }
        bind "Alt k" { MoveFocus "Up"; }
        bind "Alt j" { MoveFocus "Down"; }

        // Pane Resizing
        bind "Alt =" "Alt +" { Resize "Increase"; }
        bind "Alt -" { Resize "Decrease"; }
    }
}
