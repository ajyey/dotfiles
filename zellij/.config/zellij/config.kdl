// Zellij Configuration
// using the Rose Pine Moon theme to match WezTerm

theme "rose-pine-moon"

// Optional: you can customize UI and default layouts here
default_layout "default"

// Automatically copy to system clipboard using OSC52 (works over SSH!)
copy_on_select true
copy_command "osc52"

themes {
    rose-pine-moon {
        bg "#232136"
        fg "#e0def4"
        red "#eb6f92"
        green "#3e8fb0"
        blue "#9ccfd8"
        yellow "#f6c177"
        magenta "#c4a7e7"
        orange "#ea9a97"
        cyan "#ea9a97"
        black "#393552"
        white "#e0def4"
    }
}
